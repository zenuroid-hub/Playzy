DISCORD_TOKEN=tempel_token_bot_di_sini

# Application (Client) ID dari halaman "General Information" aplikasi kamu
CLIENT_ID=tempel_client_id_di_sini

# (Opsional) ID server untuk registrasi slash command instan saat development.
# Kosongkan untuk registrasi global (bisa butuh sampai 1 jam untuk muncul).
GUILD_ID=
